# Environment Configuration
# Copy this file to .env and update values for your environment

# =============================================================================
# Environment
# =============================================================================
# Options: dev, development, staging, prod, production
ENVIRONMENT=dev

# =============================================================================
# Database Configuration
# =============================================================================
# For Docker Compose setup:
DATABASE_URL=postgresql://stellovault:stellovault_dev@localhost:5432/stellovault

# Test database (for running tests)
TEST_DATABASE_URL=postgresql://stellovault:stellovault_dev@localhost:5433/stellovault_test

# Maximum database connections in pool
DB_MAX_CONNECTIONS=5

# =============================================================================
# Stellar/Soroban Configuration
# =============================================================================
# Horizon API URL
HORIZON_URL=https://horizon-testnet.stellar.org

# Soroban RPC URL
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Network passphrase
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Smart contract ID
CONTRACT_ID=YOUR_CONTRACT_ID_HERE

# =============================================================================
# Server Configuration
# =============================================================================
# Server port
PORT=3001

# Log level (trace, debug, info, warn, error)
RUST_LOG=info

# =============================================================================
# Security Configuration
# =============================================================================
# Webhook secret for external integrations
WEBHOOK_SECRET=

# CORS allowed origins (comma-separated)
# Leave empty for permissive mode (development only!)
CORS_ALLOWED_ORIGINS=

# Rate limiting: requests per second per IP
RATE_LIMIT_RPS=100

# =============================================================================
# JWT Authentication Configuration
# =============================================================================
# Secret key for signing JWT tokens (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=your-super-secret-key-change-in-production

# Access token time-to-live in seconds (default: 900 = 15 minutes)
JWT_ACCESS_TOKEN_TTL_SECONDS=900

# Refresh token time-to-live in days (default: 7)
JWT_REFRESH_TOKEN_TTL_DAYS=7

# Auth nonce time-to-live in seconds (default: 300 = 5 minutes)
AUTH_NONCE_TTL_SECONDS=300

# =============================================================================
# Docker Compose Settings (optional overrides)
# =============================================================================
# PostgreSQL container settings
POSTGRES_USER=stellovault
POSTGRES_PASSWORD=stellovault_dev
POSTGRES_DB=stellovault
POSTGRES_PORT=5432

# =============================================================================
# Risk Engine: DeFi History Provider
# =============================================================================
# Soroswap API configuration
SOROSWAP_API_URL=https://api.soroswap.finance/v1
SOROSWAP_API_KEY=
SOROSWAP_RATE_LIMIT_RPM=60
SOROSWAP_CACHE_TTL_SECONDS=600

# Aquarius API configuration
AQUARIUS_API_URL=https://api.aquarius.network/v1
AQUARIUS_API_KEY=
AQUARIUS_RATE_LIMIT_RPM=60
AQUARIUS_CACHE_TTL_SECONDS=600

# DeFi data fetching settings
DEFI_HISTORY_DAYS=90
DEFI_API_TIMEOUT_SECONDS=30
DEFI_HISTORY_ENABLED=true

# =============================================================================
# Risk Engine: Document Verification
# =============================================================================
# OCR provider: textract, gpt4_vision, tesseract
OCR_PROVIDER=textract

# AWS Textract (if OCR_PROVIDER=textract)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=stellovault-documents
AWS_S3_REGION=us-east-1

# OpenAI GPT-4 Vision (if OCR_PROVIDER=gpt4_vision)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-vision-preview
OPENAI_MAX_TOKENS=4096

# Document storage configuration
DOCUMENT_STORAGE=local
DOCUMENT_STORAGE_PATH=./storage/documents
DOCUMENT_MAX_SIZE_MB=10
DOCUMENT_ALLOWED_TYPES=pdf,png,jpg,jpeg
DOCUMENT_RETENTION_DAYS=365

# Document verification settings
DOCUMENT_MIN_CONFIDENCE=75
DOCUMENT_MANUAL_REVIEW_ENABLED=true
DOCUMENT_FRAUD_DETECTION_LEVEL=medium

# =============================================================================
# Risk Engine: Score Configuration
# =============================================================================
# Component weights (must sum to 1.0)
RISK_WEIGHT_ON_CHAIN_ACTIVITY=0.40
RISK_WEIGHT_REPAYMENT_HISTORY=0.40
RISK_WEIGHT_COLLATERAL_QUALITY=0.20

# Risk calculation settings
RISK_CALCULATION_VERSION=v2.0
RISK_SCORE_CACHE_TTL_SECONDS=3600
RISK_SCORE_EXPIRY_HOURS=24

# Risk tier thresholds (0-1000 scale)
RISK_TIER_EXCELLENT_MIN=850
RISK_TIER_GOOD_MIN=700
RISK_TIER_FAIR_MIN=550
RISK_TIER_POOR_MIN=400

# =============================================================================
# Optional: Redis Caching
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_ENABLED=false
REDIS_POOL_SIZE=10

# =============================================================================
# Optional: Background Workers
# =============================================================================
RISK_WORKER_ENABLED=false
RISK_WORKER_REFRESH_INTERVAL_HOURS=6
RISK_WORKER_CONCURRENCY=5
